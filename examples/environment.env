# ONDEWO CSI Client JS — examples configuration (template, NO real secrets).
#
# Copy real values in locally; this committed file only holds non-secret placeholders.
# Every example under examples/ loads this file via dotenv (path relative to the script).

# --- Connection (Envoy gRPC-web endpoint) ---
ONDEWO_HOST=localhost
ONDEWO_PORT=50055

# --- Keycloak (headless ROPC + offline_access login for the bearer token) ---
KEYCLOAK_URL=https://localhost/auth
KEYCLOAK_REALM=ondewo
KEYCLOAK_CLIENT_ID=ondewo-nlu-cai-sdk-public
KEYCLOAK_USER_NAME=
KEYCLOAK_PASSWORD=
# TLS certificate verification for the Keycloak token call (true/false).
KEYCLOAK_VERIFY_SSL=true

# --- CSI service-specific ---
ONDEWO_CSI_S2S_PIPELINE_ID=
